# Taro 客户端 — 炼金音坊
# Copy-Item .env.example .env

# 后端 API（build:h5 / build:weapp / 小程序真机）
# H5 dev 自动走 /api/v1 代理，无需改此值
#
# 微信小程序 / 真机：必须填本机局域网 IP 或 HTTPS 合法域名
# 示例：TARO_APP_API_URL=http://192.168.1.100:8000/api/v1
# 勿用 localhost / 127.0.0.1 / 相对路径 /api/v1
# 修改后必须重新 npm run build:mp 或 dev:mp
TARO_APP_API_URL=http://192.168.1.100:8000/api/v1

# 可选，与根 .env WECHAT_APP_ID 一致
# TARO_APP_ID=wxXXXXXXXXXXXXXXXX

# 微信开发者工具 → 详情 → 本地设置 → 不校验合法域名（开发阶段）
# 验收：启动小程序后 Network 应出现 /api/v1/config/flags 等业务请求，而不只有 SdkReport
