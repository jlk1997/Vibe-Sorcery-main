# =============================================================================
# Vibe Sorcery — 环境变量模板
# 使用：Copy-Item .env.example .env  然后编辑 .env
# 客户端：Copy-Item apps\client\.env.example apps\client\.env
# =============================================================================

# --- 应用 ---
APP_NAME=Vibe Sorcery
APP_VERSION=3.0.0
DEBUG=true
API_PREFIX=/api/v1
PIPELINE_VERSION=vibe-sorcery/3.0.0

# --- 多租户（Admin Feature Flag multi_tenant 开启后生效）---
DEFAULT_TENANT_ID=default
MULTI_TENANT_ENABLED=false

# --- MiniMax AI ---
MINIMAX_API_KEY=
# 国内：https://api.minimaxi.com/v1 | 国际：https://api.minimax.io/v1
MINIMAX_API_BASE=https://api.minimaxi.com/v1
MINIMAX_MUSIC_MODEL=music-2.6
# music-2.6 需 Token Plan/付费；限免可用 music-2.6-free。流式仅支持 hex，失败会自动重试并回退非流式。
# 官方文档：https://platform.minimaxi.com/docs/guides/music-generation
# 若持续报「准备失败」，可临时设 MINIMAX_MUSIC_STREAM=false
MINIMAX_MUSIC_COVER_MODEL=music-cover
MINIMAX_CHAT_MODEL=MiniMax-M3
MINIMAX_IMAGE_MODEL=image-01
MINIMAX_MUSIC_OUTPUT_FORMAT=hex
MINIMAX_MUSIC_STREAM=true
MINIMAX_MUSIC_SAMPLE_RATE=44100
MINIMAX_MUSIC_BITRATE=256000
MINIMAX_MUSIC_FORMAT=mp3
MINIMAX_LYRICS_OPTIMIZER_DEFAULT=false
MINIMAX_COVER_MODE_DEFAULT=one_step
MINIMAX_MUSIC_TIMEOUT_SECONDS=600
MINIMAX_CHAT_TIMEOUT_SECONDS=120
MINIMAX_HTTP_RETRIES=3
MINIMAX_HTTP_TRUST_ENV=false
# 无 MiniMax Key 时设为 true，可跑通注册/生成/溯源全流程
DEV_MOCK_GENERATION=true

# --- 数据库 ---
# 本地 Docker：5433 | 容器内服务互联：postgres:5432（compose 自动覆盖）
DATABASE_URL=postgresql://vibe:vibe@localhost:5433/vibe_sorcery

# --- Redis / Celery（分库：0=缓存/ticket/pubsub 1=broker 2=result）---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
# 生产建议：RATE_LIMIT_FAIL_CLOSED=true（Redis 不可用时拒绝生成）
RATE_LIMIT_FAIL_CLOSED=false
# Worker 池（dev 默认 solo；生产 prefork + 并发）
CELERY_WORKER_POOL=solo
CELERY_WORKER_CONCURRENCY=1
# Docker 生成 worker：CELERY_POOL=prefork CELERY_CONCURRENCY=2 -Q celery,priority
# Docker 后处理 worker：CELERY_POST_CONCURRENCY=2 -Q post_process（见 docker-compose worker-post）
CELERY_POST_CONCURRENCY=2
CELERY_TASK_TIME_LIMIT_SECONDS=1800
CELERY_TASK_SOFT_TIME_LIMIT_SECONDS=1740
# MiniMax 并发：同一 worker 进程内最多同时打几个上游请求（防 RPM 1002）
MINIMAX_MAX_INFLIGHT=2
MINIMAX_HTTP_MAX_CONNECTIONS=16
MINIMAX_HTTP_MAX_KEEPALIVE=8
# prefork + concurrency>1 时变体子任务并行 apply_async；solo 下仍串行 .apply()
VARIATION_PARALLEL=true
# 每用户并发 active job 上限：免费 1 / 订阅 2（代码内置，非 env）

# --- JWT ---
JWT_SECRET=change-me-generate-a-long-random-secret-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# --- 管理员引导 ---
# 仅当尚无 admin 时提升匹配邮箱用户；生产建议留空，手动 grant admin
ADMIN_BOOTSTRAP_EMAIL=

# --- WebSocket 任务流 ticket TTL（秒）---
WS_STREAM_TICKET_TTL_SECONDS=120

# --- S3 / MinIO ---
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=vibe-sorcery
S3_REGION=us-east-1
S3_USE_SSL=false

# --- CDN（留空则回退 S3_PUBLIC_ENDPOINT）---
CDN_BASE_URL=

# --- Essentia 模型（留空 = 项目根 models/）---
MODELS_DIR=

# --- 媒体 / 溯源 ---
FFMPEG_PATH=ffmpeg
C2PA_ENABLED=true
BLOCKCHAIN_ANCHOR_ENABLED=false
BLOCKCHAIN_RPC_URL=
BLOCKCHAIN_CONTRACT=

# =============================================================================
# 商业生态 — 计费 / 支付 / 订阅
# =============================================================================

# 支付异步通知基址（微信/支付宝 MUST 外网 HTTPS；本地 Mock 可用 localhost）
API_PUBLIC_URL=http://localhost:8000/api/v1

# Stripe Checkout 成功/取消回跳（Taro H5）
FRONTEND_BASE_URL=http://localhost:10086

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300
STRIPE_SUBSCRIPTION_PRICE_ID=
STRIPE_SUBSCRIPTION_YEARLY_PRICE_ID=

SUBSCRIPTION_MONTHLY_CREDITS=30
PAYMENT_ORDER_TTL_HOURS=2
RATE_LIMIT_FAIL_CLOSED=true

# 混合免费额度（商业生态）
# --- 额度经济 ---
# 默认开启门控（与 DEBUG 无关）；设为 false 可关闭扣费（仅运维调试用）
CREDITS_GATE_ENABLED=true
WELCOME_CREDITS=25
DAILY_CHECKIN_CREDITS=1
TASK_CREDITS_FIRST_PUBLISH=3
TASK_CREDITS_JOURNEY_FEEDBACK=2
TASK_CREDITS_FIRST_REMIX=1
TASK_CREDITS_FIRST_CHALLENGE=2

# Celery worker 需监听双队列：celery,priority
# 微信小程序 + 支付（API v2 MD5；需商户开通 JSAPI，并关联本 AppID）
# 必填：APP_ID + APP_SECRET + MCH_ID + API_KEY(v2 32位，勿用 v3)
# 真机回调：API_PUBLIC_URL 须公网 HTTPS → …/billing/wechat/notify
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_KEY=
# 小程序订阅消息模板 ID（微信公众平台申请）
WECHAT_TPL_JOB_COMPLETE=
WECHAT_TPL_LOW_CREDITS=

# 支付宝 RSA2
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_SANDBOX=true

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:10086,http://127.0.0.1:10086,http://localhost:3001,http://127.0.0.1:3001,http://localhost:8081

# --- Docker 构建（pip 下载慢/超时时用国内镜像）---
# PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
# 海外可改为：https://pypi.org/simple

# --- 合规 / 法律信息（H5 页脚与协议页）---
# LEGAL_ICP_NUMBER=京ICP备XXXXXXXX号
LEGAL_CONTACT_EMAIL=privacy@vibe-sorcery.com
LEGAL_CONTACT_PHONE=400-000-0000
LEGAL_COMPANY_NAME=炼金音坊

# =============================================================================
# 客户端 apps/client/.env
#   TARO_APP_API_URL=http://localhost:8000/api/v1
#   TARO_APP_ID=wxXXXXXXXX（可选，与 WECHAT_APP_ID 一致）
# =============================================================================
